                },
                {
                    "name": "Get All Volumes (Mock)",
                    "request": {
                        "method": "GET",
                        "url": {
                            "raw": "{{fusionMockUrl}}/v1/volumes",
                            "host": [
                                "{{fusionMockUrl}}"
                            ],
                            "path": [
                                "v1",
                                "volumes"
                            ]
                        }
                    }
                },
                {
                    "name": "Delete Volume (Mock)",
                    "request": {
                        "method": "DELETE",
                        "url": {
                            "raw": "{{fusionMockUrl}}/v1/volumes/:id",
                            "host": [
                                "{{fusionMockUrl}}"
                            ],
                            "path": [
                                "v1",
                                "volumes",
                                ":id"
                            ],
                            "variable": [
                                {
                                    "key": "id",
                                    "value": ""
                                }
                            ]
                        }
                    }
                }
            ]
        }
    ],
    "variable": [
        {
            "key": "baseUrl",
            "value": "http://localhost:3000",
            "type": "string"
        },
        {
            "key": "fusionMockUrl",
            "value": "http://localhost:3001",
            "type": "string"
        },
        {
            "key": "token",
            "value": "",
            "type": "string"
        }
    ]
