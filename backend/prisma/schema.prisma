// Prisma Schema for Pure Fusion Portal

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  volumes Volume[]
  logs    Log[]

  @@map("users")
}

model Volume {
  id                String   @id @default(uuid())
  name              String   @unique
  sizeGb            Int      @map("size_gb")
  performanceClass  String   @map("performance_class")
  protectionPolicy  String   @map("protection_policy")
  environment       String
  tags              String   // JSON string
  status            String   @default("creating")
  placement         String?
  fusionVolumeId    String?  @map("fusion_volume_id")
  createdBy         String   @map("created_by")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  // Relations
  user User @relation(fields: [createdBy], references: [id])

  @@map("volumes")
}

model Log {
  id        String   @id @default(uuid())
  type      String   // request, error, lifecycle
  message   String
  payload   String?  // JSON string
  userId    String?  @map("user_id")
  timestamp DateTime @default(now())

  // Relations
  user User? @relation(fields: [userId], references: [id])

  @@map("logs")
}
